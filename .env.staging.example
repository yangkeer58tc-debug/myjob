# 预发布/测试环境变量模板
# 用法：
#   cp .env.staging.example .env.staging
#   按你的 Staging 项目填写后：npm run build:staging && npm run preview:staging
# Cloudflare Pages（第二个项目或同一项目的 Preview）：在控制台为 Staging 填相同名称的变量。

# 公网访问的站点根地址（用于 canonical、OG 等，勿带末尾斜杠）
VITE_SITE_URL=https://staging.example.com

# WhatsApp 联系：`npm run build:staging` 会使用 staging WABA（5218132689445）；也可在此覆盖：
# VITE_WHATSAPP_BOT_NUMBER=5218132689445

# 主站 Supabase（若 Staging 用独立库，填 Staging 项目的 URL 与 anon key）
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# 简历/Candidate 搜索（若使用）
# VITE_RESUMES_SUPABASE_URL=
# VITE_RESUMES_SUPABASE_ANON_KEY=
# VITE_RESUMES_PUBLIC_VIEW=public_candidates

# 可选：LLM / 职位摘要（与线上一致或单独测试 key）
# VITE_OPENAI_API_KEY=
# VITE_OPENAI_API_BASE_URL=
# VITE_OPENAI_MODEL=gpt-4o-mini
# 或通过构建时进程环境注入 LLM_API_KEY、LLM_BASE_URL、LLM_MODEL（见 vite.config）

# 可选：自建摘要接口
# VITE_JOB_AI_URL=
# VITE_JOB_AI_API_KEY=

# ----------------------------------------------------------------------
# WhatsApp Bot (Infobip) – 这些只用于 Supabase Edge Function，不会进前端 bundle。
# 在 Supabase 控制台 -> Edge Functions -> Manage secrets 里设置同名变量即可。
# 本地仅作为 documentation/示意用。
# ----------------------------------------------------------------------
# INFOBIP_BASE_URL=https://1ex1wk.api.infobip.com
# INFOBIP_API_KEY=
# INFOBIP_SENDER=5218132689445

# 可选：兜底 AI 回复（暂未启用，MVP 仅用规则）
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
