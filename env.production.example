# 生产环境变量模板
# 用法：
#   在 Cloudflare Pages 的 Production 环境中设置同名变量。

# 公网访问站点根地址（无尾斜杠）
VITE_SITE_URL=https://myjob.example.com

# 主站 Supabase（生产项目）
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# 简历/Candidate 搜索（若使用）
# VITE_RESUMES_SUPABASE_URL=
# VITE_RESUMES_SUPABASE_ANON_KEY=
# VITE_RESUMES_PUBLIC_VIEW=public_candidates

# 可选：前端公开的 LLM/摘要配置（如果确实需要放前端）
# VITE_OPENAI_API_KEY=
# VITE_OPENAI_API_BASE_URL=
# VITE_OPENAI_MODEL=gpt-4o-mini

